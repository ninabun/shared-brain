rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isWorkspaceMember(workspaceId) {
      return request.auth != null
        && (
          request.auth.token.email == "ninadabun@gmail.com"
          || firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid))
        );
    }

    match /workspaces/{workspaceId}/idea-assets/{allPaths=**} {
      allow read, write: if isWorkspaceMember(workspaceId);
    }
  }
}
